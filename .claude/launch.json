{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server (porta 8080)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "npx serve (porta 3000)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "3000"],
      "port": 3000
    }
  ]
}
