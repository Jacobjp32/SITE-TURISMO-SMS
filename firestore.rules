rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function hasRole(roles) {
      return signedIn() && userDoc().data.role in roles && userDoc().data.ativo != false;
    }

    function isAdmin() {
      return hasRole(['admin']);
    }

    function isModerator() {
      return hasRole(['admin', 'moderator']);
    }

    function owns(resourceData) {
      return signedIn() && resourceData.submittedBy == request.auth.uid;
    }

    function ownsUserId(resourceData) {
      return signedIn() && resourceData.userId == request.auth.uid;
    }

    function ownsOwnerUid(resourceData) {
      return signedIn() && resourceData.ownerUid == request.auth.uid;
    }

    function managerDoc(managerId) {
      return get(/databases/$(database)/documents/establishment_managers/$(managerId));
    }

    function validPendingEventCreateBase(eventId) {
      return signedIn() &&
        request.resource.data.id == eventId &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.status == 'pendente' &&
        request.resource.data.submittedByEmail == request.auth.token.email &&
        request.resource.data.ownerEmail == request.auth.token.email;
    }

    function validCommonPendingEventCreate(eventId) {
      return validPendingEventCreateBase(eventId) &&
        request.resource.data.source == 'portal_usuario' &&
        request.resource.data.linkedManagerId == null &&
        request.resource.data.linkedEstablishmentId == null &&
        request.resource.data.linkedEstablishmentName == null &&
        request.resource.data.linkedEstablishmentRole == null;
    }

    function validLinkedPendingEventCreate(eventId) {
      return validPendingEventCreateBase(eventId) &&
        request.resource.data.source == 'establishment_manager' &&
        request.resource.data.linkedManagerId is string &&
        request.resource.data.linkedEstablishmentId is string &&
        request.resource.data.linkedEstablishmentName is string &&
        request.resource.data.linkedEstablishmentRole in ['proprietario', 'gerente_responsavel', 'representante_autorizado'] &&
        exists(/databases/$(database)/documents/establishment_managers/$(request.resource.data.linkedManagerId)) &&
        managerDoc(request.resource.data.linkedManagerId).data.userId == request.auth.uid &&
        managerDoc(request.resource.data.linkedManagerId).data.active == true &&
        managerDoc(request.resource.data.linkedManagerId).data.establishmentId == request.resource.data.linkedEstablishmentId &&
        managerDoc(request.resource.data.linkedManagerId).data.establishmentName == request.resource.data.linkedEstablishmentName &&
        managerDoc(request.resource.data.linkedManagerId).data.role == request.resource.data.linkedEstablishmentRole;
    }

    // --- Banners / Pop-ups (Bloco 4B) ---
    // Schema e decisoes em docs/bloco-4b-rules-banners.md.
    // Leitura publica: apenas status == 'published' (janela startAt/endAt
    // filtrada no client). Escrita: somente isAdmin(). Sem delete direto.
    function isBannerType(value) {
      return value in ['banner', 'popup'];
    }

    function isBannerStatus(value) {
      return value in ['draft', 'published', 'archived'];
    }

    function bannerFieldsAllowed(data) {
      return data.keys().hasOnly([
        'id', 'title', 'slug', 'description', 'type', 'status', 'placement',
        'targetPages', 'imageUrl', 'imagePath', 'imageAlt', 'mediaId',
        'imageUpdatedAt', 'imageUpdatedBy',
        'ctaLabel', 'ctaUrl', 'ctaTarget', 'startAt', 'endAt', 'priority',
        'frequency', 'dismissible', 'showDelayMs', 'maxWidth',
        'createdAt', 'updatedAt', 'createdBy', 'updatedBy',
        'publishedAt', 'archivedAt'
      ]);
    }

    function bannerHasImage(data) {
      return (data.imageUrl is string && data.imageUrl.size() > 0) ||
        (data.mediaId is string && data.mediaId.size() > 0);
    }

    function bannerHasPlacement(data) {
      return (data.placement is string && data.placement.size() > 0) ||
        (data.targetPages is list && data.targetPages.size() > 0);
    }

    function isValidBannerBase(data) {
      return data.title is string && data.title.size() > 0 &&
        isBannerType(data.type) &&
        isBannerStatus(data.status) &&
        bannerFieldsAllowed(data);
    }

    // Janela de datas: so valida coerencia quando ambos definidos.
    function bannerDatesOk(data) {
      return !(data.startAt != null && data.endAt != null) ||
        data.endAt > data.startAt;
    }

    // Para publicar exige imagem (url ou mediaId) e destino (placement/targetPages).
    function isValidBannerPublished(data) {
      return data.status != 'published' ||
        (bannerHasImage(data) && bannerHasPlacement(data));
    }

    function isValidBannerCreate(bannerId) {
      return isAdmin() &&
        request.resource.data.id == bannerId &&
        isValidBannerBase(request.resource.data) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        bannerDatesOk(request.resource.data) &&
        isValidBannerPublished(request.resource.data);
    }

    function isValidBannerUpdate() {
      return isAdmin() &&
        request.resource.data.id == resource.data.id &&
        isValidBannerBase(request.resource.data) &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt is timestamp &&
        bannerDatesOk(request.resource.data) &&
        isValidBannerPublished(request.resource.data);
    }

    // --- CMS-2B: Empreendimentos internos ---
    // CRUD interno do painel admin. Neste bloco NAO ha leitura publica desta
    // collection, mesmo para status "published"; o site publico ainda nao usa
    // Firestore para empreendimentos.
    function isEstablishmentStatus(value) {
      return value in ['draft', 'published', 'archived'];
    }

    function isDeletableEstablishmentStatus(value) {
      return value in ['draft', 'archived'];
    }

    function establishmentFieldsAllowed(data) {
      return data.keys().hasOnly([
        'id', 'slug', 'name', 'categoryId', 'categoryLabel', 'status',
        'content', 'contact', 'location', 'media', 'relationships',
        'display', 'seo', 'publishing', 'review', 'source',
        'createdAt', 'createdBy', 'updatedAt', 'updatedBy'
      ]);
    }

    function validNullableTimestamp(value) {
      return value == null || value is timestamp;
    }

    function validStringList(value) {
      return value is list && value.size() <= 50;
    }

    function validNullableCoordinate(value) {
      return value == null || value is number;
    }

    function validEstablishmentImage(data) {
      return data is map &&
        data.keys().hasOnly(['url', 'path', 'alt', 'caption', 'credit', 'source']) &&
        data.url is string &&
        data.path is string &&
        data.alt is string &&
        data.caption is string &&
        data.credit is string &&
        data.source is string;
    }

    function validEstablishmentContent(data) {
      return data is map &&
        data.keys().hasOnly([
          'summary', 'description', 'longDescription', 'accessibility',
          'openingHours', 'tags', 'notesInternal'
        ]) &&
        data.summary is string &&
        data.description is string &&
        data.longDescription is string &&
        data.accessibility is string &&
        data.openingHours is string &&
        validStringList(data.tags) &&
        data.notesInternal is string;
    }

    function validEstablishmentContact(data) {
      return data is map &&
        data.keys().hasOnly(['phone', 'whatsapp', 'email', 'website', 'instagram', 'facebook']) &&
        data.phone is string &&
        data.whatsapp is string &&
        data.email is string &&
        data.website is string &&
        data.instagram is string &&
        data.facebook is string;
    }

    function validEstablishmentLocation(data) {
      return data is map &&
        data.keys().hasOnly([
          'address', 'neighborhood', 'city', 'state', 'postalCode',
          'coordinates', 'mapsUrl', 'coordStatus', 'coordNote'
        ]) &&
        data.address is string &&
        data.neighborhood is string &&
        data.city is string &&
        data.state is string &&
        data.postalCode is string &&
        data.coordinates is map &&
        data.coordinates.keys().hasOnly(['lat', 'lng']) &&
        validNullableCoordinate(data.coordinates.lat) &&
        validNullableCoordinate(data.coordinates.lng) &&
        data.mapsUrl is string &&
        data.coordStatus is string &&
        data.coordNote is string;
    }

    function validEstablishmentMedia(data) {
      return data is map &&
        data.keys().hasOnly(['mainImage', 'gallery', 'videoUrl', 'sourceCredits']) &&
        validEstablishmentImage(data.mainImage) &&
        data.gallery is list &&
        data.gallery.size() <= 60 &&
        data.videoUrl is string &&
        data.sourceCredits is string;
    }

    function validEstablishmentRelationships(data) {
      return data is map &&
        data.keys().hasOnly([
          'routeIds', 'relatedPlaceIds', 'relatedEventIds',
          'legacyRoute', 'legacyRouteName'
        ]) &&
        validStringList(data.routeIds) &&
        validStringList(data.relatedPlaceIds) &&
        validStringList(data.relatedEventIds) &&
        data.legacyRoute is string &&
        data.legacyRouteName is string;
    }

    function validEstablishmentDisplay(data) {
      return data is map &&
        data.keys().hasOnly(['featured', 'priority', 'mapVisible', 'claimable']) &&
        data.featured is bool &&
        data.priority is int &&
        data.mapVisible is bool &&
        data.claimable is bool;
    }

    function validEstablishmentSeo(data) {
      return data is map &&
        data.keys().hasOnly(['title', 'description', 'canonicalPath']) &&
        data.title is string &&
        data.description is string &&
        data.canonicalPath is string;
    }

    function validEstablishmentPublishing(data) {
      return data is map &&
        data.keys().hasOnly([
          'publishedAt', 'publishedBy', 'archivedAt', 'archivedBy', 'archiveReason'
        ]) &&
        validNullableTimestamp(data.publishedAt) &&
        data.publishedBy is string &&
        validNullableTimestamp(data.archivedAt) &&
        data.archivedBy is string &&
        data.archiveReason is string;
    }

    function validEstablishmentReview(data) {
      return data is map &&
        data.keys().hasOnly([
          'lastAppliedRequestId', 'lastAppliedAt', 'lastAppliedBy', 'lastReviewNotes'
        ]) &&
        data.lastAppliedRequestId is string &&
        validNullableTimestamp(data.lastAppliedAt) &&
        data.lastAppliedBy is string &&
        data.lastReviewNotes is string;
    }

    function validEstablishmentSource(data) {
      return data is map &&
        data.keys().hasOnly([
          'origin', 'sourceFile', 'originalId', 'originalCategory',
          'legacyIds', 'seededAt', 'sourceUpdatedAt'
        ]) &&
        data.origin is string &&
        data.sourceFile is string &&
        data.originalId is string &&
        data.originalCategory is string &&
        validStringList(data.legacyIds) &&
        validNullableTimestamp(data.seededAt) &&
        validNullableTimestamp(data.sourceUpdatedAt);
    }

    function validEstablishmentBase(data) {
      return establishmentFieldsAllowed(data) &&
        data.id is string &&
        data.slug is string &&
        data.name is string &&
        data.categoryId is string &&
        data.categoryLabel is string &&
        isEstablishmentStatus(data.status) &&
        data.name.size() > 0 &&
        data.slug.size() > 0 &&
        data.categoryId.size() > 0 &&
        data.categoryLabel.size() > 0 &&
        validEstablishmentContent(data.content) &&
        validEstablishmentContact(data.contact) &&
        validEstablishmentLocation(data.location) &&
        validEstablishmentMedia(data.media) &&
        validEstablishmentRelationships(data.relationships) &&
        validEstablishmentDisplay(data.display) &&
        validEstablishmentSeo(data.seo) &&
        validEstablishmentPublishing(data.publishing) &&
        validEstablishmentReview(data.review) &&
        validEstablishmentSource(data.source) &&
        data.createdAt is timestamp &&
        data.createdBy is string &&
        data.updatedAt is timestamp &&
        data.updatedBy is string;
    }

    function isValidEstablishmentCreate(establishmentId) {
      return isAdmin() &&
        request.resource.data.id == establishmentId &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.updatedBy == request.auth.uid &&
        validEstablishmentBase(request.resource.data);
    }

    function isValidEstablishmentUpdate() {
      return isAdmin() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedBy == request.auth.uid &&
        validEstablishmentBase(request.resource.data);
    }

    match /usuarios/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if isAdmin() || (
        signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.role == 'user' &&
        request.resource.data.ativo == true
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['nome', 'telefone', 'tipo', 'organizacao']) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.ativo == resource.data.ativo
      );
      allow delete: if isAdmin();
    }

    match /eventos_pendentes/{eventId} {
      allow read: if isModerator() || owns(resource.data);
      allow create: if validCommonPendingEventCreate(eventId) ||
        validLinkedPendingEventCreate(eventId);
      allow update: if isModerator();
      allow delete: if isModerator();
    }

    match /estabelecimentos_pendentes/{estId} {
      allow read: if isModerator() || owns(resource.data);
      allow create: if signedIn() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.status == 'pendente';
      allow update: if isModerator();
      allow delete: if isModerator();
    }

    match /eventos_aprovados/{eventId} {
      allow read: if true;
      allow write: if isModerator();
    }

    match /estabelecimentos_aprovados/{estId} {
      allow read: if true;
      allow write: if isModerator();
    }

    match /establishment_claims/{claimId} {
      allow read: if isModerator() || ownsUserId(resource.data);
      allow create: if signedIn() &&
        request.resource.data.id == claimId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userEmail == request.auth.token.email &&
        request.resource.data.status == 'pending' &&
        request.resource.data.source == 'portal_usuario' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.reviewedBy == null &&
        request.resource.data.reviewNotes == '' &&
        request.resource.data.rejectionReason == '' &&
        request.resource.data.requestedRole in ['proprietario', 'gerente_responsavel', 'representante_autorizado'] &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'userEmail',
          'userName',
          'contactPhone',
          'establishmentId',
          'establishmentName',
          'establishmentCategory',
          'establishmentSource',
          'establishmentOriginalId',
          'requestedRole',
          'status',
          'message',
          'createdAt',
          'updatedAt',
          'reviewedAt',
          'reviewedBy',
          'reviewNotes',
          'rejectionReason',
          'source'
        ]);
      allow update, delete: if isModerator();
    }

    match /establishment_managers/{managerId} {
      allow read: if isModerator() || (
        ownsUserId(resource.data) &&
        resource.data.active == true
      );
      allow create, update, delete: if isModerator();
    }

    match /establishment_update_requests/{requestId} {
      allow read: if isModerator() || ownsOwnerUid(resource.data);
      allow create: if signedIn() &&
        request.resource.data.id == requestId &&
        request.resource.data.managerId is string &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerEmail == request.auth.token.email &&
        request.resource.data.status == 'pending' &&
        request.resource.data.source == 'establishment_manager' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.reviewedBy == null &&
        request.resource.data.reviewNotes == '' &&
        request.resource.data.rejectionReason == '' &&
        request.resource.data.changesRequestedNotes == '' &&
        exists(/databases/$(database)/documents/establishment_managers/$(request.resource.data.managerId)) &&
        managerDoc(request.resource.data.managerId).data.userId == request.auth.uid &&
        managerDoc(request.resource.data.managerId).data.active == true &&
        managerDoc(request.resource.data.managerId).data.establishmentId == request.resource.data.establishmentId &&
        managerDoc(request.resource.data.managerId).data.establishmentName == request.resource.data.establishmentName &&
        request.resource.data.currentSnapshot is map &&
        request.resource.data.currentSnapshot.keys().hasOnly([
          'name',
          'category',
          'source',
          'originalId',
          'description',
          'phone',
          'whatsapp',
          'instagram',
          'website',
          'address',
          'openingHours',
          'images',
          'mainImage',
          'imageCount'
        ]) &&
        request.resource.data.requestedChanges is map &&
        request.resource.data.requestedChanges.keys().hasOnly([
          'description',
          'phone',
          'whatsapp',
          'instagram',
          'website',
          'address',
          'openingHours',
          'additionalNotes'
        ]) &&
        (
          request.resource.data.requestedChanges.keys().size() > 0 ||
          request.resource.data.imageCount > 0
        ) &&
        request.resource.data.images is list &&
        request.resource.data.imageCount == request.resource.data.images.size() &&
        request.resource.data.keys().hasOnly([
          'id',
          'managerId',
          'ownerUid',
          'ownerEmail',
          'ownerName',
          'establishmentId',
          'establishmentName',
          'establishmentCategory',
          'establishmentSource',
          'currentSnapshot',
          'requestedChanges',
          'images',
          'mainImage',
          'imageCount',
          'status',
          'source',
          'createdAt',
          'updatedAt',
          'submittedAt',
          'reviewedAt',
          'reviewedBy',
          'reviewNotes',
          'rejectionReason',
          'changesRequestedNotes'
        ]);
      allow update, delete: if isModerator();
    }

    match /cms_establishments/{establishmentId} {
      allow read: if isAdmin();
      allow create: if isValidEstablishmentCreate(establishmentId);
      allow update: if isValidEstablishmentUpdate();
      allow delete: if isAdmin() && isDeletableEstablishmentStatus(resource.data.status);
    }

    match /noticias/{noticiaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /media_library/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reservas/{reservaId} {
      allow create: if request.resource.data.status == 'pendente' &&
        request.resource.data.keys().hasOnly([
          'id',
          'experienciaId',
          'experienciaNome',
          'data',
          'horario',
          'pessoas',
          'nome',
          'email',
          'telefone',
          'observacoes',
          'valorTotal',
          'status',
          'criadaEm',
          'criadoEm',
          'firestoreId'
        ]);
      allow read, update, delete: if isAdmin();
    }

    match /banners/{bannerId} {
      // Publico le apenas banners publicados; admin le todos.
      allow read: if isAdmin() || resource.data.status == 'published';
      allow create: if isValidBannerCreate(bannerId);
      allow update: if isValidBannerUpdate();
      // Sem delete direto nesta fase: usar status 'archived'.
      // Outras collections usam delete por moderador/admin, mas banners
      // ficam mais seguros sem exclusao definitiva (ver doc 4B).
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
